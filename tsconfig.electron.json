{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "lib": ["ES2022"],
        "noEmit": false,
        "outDir": "dist-electron",
        "rootDir": "src",
        "types": ["node", "electron"],
        "isolatedModules": false,
        "allowImportingTsExtensions": false
    },
    "include": ["src/electron/**/*.ts", "src/shared/**/*.ts", "src/backend/**/*.ts"]
}
