# Preferred Electrobun signing identity used by Electrobun for macOS code signing.
# Where to get it:
# 1. Install Xcode and sign into your Apple Developer account in Xcode -> Settings -> Accounts.
# 2. In Xcode, open Manage Certificates and create or confirm a "Developer ID Application" certificate.
# 3. Open Keychain Access and search for "Developer ID Application" in the login keychain.
# 4. Copy either:
#    - the full certificate label, for example "Developer ID Application: Your Name (TEAMID)", or
#    - the shorter name fragment, for example "Your Name (TEAMID)".
# 5. Paste that value here.
ELECTROBUN_DEVELOPER_ID=""

# Your Apple Developer Team ID.
# Where to get it:
# 1. Sign in to https://developer.apple.com/account/.
# 2. Open Membership and look for the Team ID / App ID Prefix value.
# 3. You can also find it under Certificates, Identifiers & Profiles on your app identifier details.
# 4. It looks like a 10-character value such as "BGU899NB8T".
ELECTROBUN_TEAMID=""

# Apple ID email used for notarization with notarytool.
# Where to get it:
# 1. Use the Apple ID that has access to your Apple Developer team.
# 2. This is usually the email address you use to sign in to developer.apple.com.
# 3. Paste the full email address here.
ELECTROBUN_APPLEID=""

# App-specific password for the Apple ID above, used for notarization.
# Where to get it:
# 1. Sign in to https://account.apple.com/.
# 2. Open Sign-In and Security -> App-Specific Passwords.
# 3. Create a new app-specific password for Electrobun or Gitvan release builds.
# 4. Paste the generated password value here.
ELECTROBUN_APPLEIDPASS=""

# Optional local path used only for the real-app integration test fixture.
# Where to get it:
# 1. Only set this if you intentionally run the real-app integration test.
# 2. Point it at an existing local Gitvan SQLite database file on your machine.
# 3. Use an absolute path, for example "/Users/you/Library/Application Support/Gitvan/gitvan.sqlite".
GITVAN_REAL_DATABASE_PATH="/absolute/path/to/gitvan.sqlite"