{
    "$schema": "./node_modules/oxlint/configuration_schema.json",
    "rules": {
        "no-floating-promises": "allow",
        "no-unused-vars": "off",
        "no-empty-file": "off",
        "consistent-type-imports": "error"
    },
    "options": {
        "typeCheck": true,
        "typeAware": true
    }
}
