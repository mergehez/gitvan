{
    "name": "gitvan",
    "version": "0.0.2",
    "description": "Gitvan desktop Git client with Vue and Vite",
    "license": "MIT",
    "author": {
        "name": "Mergesoft"
    },
    "type": "module",
    "main": "dist-electron/electron/main.js",
    "scripts": {
        "b": "npm run b:renderer && npm run b:electron",
        "b:renderer": "vp build",
        "b:electron": "tsc -p tsconfig.electron.json",
        "test:ui": "vitest run",
        "test:release": "vitest run --exclude tests/App.real.spec.ts",
        "release:audit": "bash ./scripts/release-audit.sh",
        "release:validate": "npm run test:release && npm run b",
        "release:prepare": "tsx ./scripts/prepare.ts",
        "release:prepare:test": "tsx ./scripts/prepare.ts --test",
        "release:mac": "tsx ./scripts/build.ts",
        "release:mac:signed": "tsx ./scripts/build.ts --signed",
        "release:mac:notarized": "tsx ./scripts/build.ts --notarize",
        "start": "npm run b && NODE_OPTIONS=--disable-warning=ExperimentalWarning electron .",
        "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\" \"npm run dev:app\"",
        "dev:renderer": "vp dev",
        "dev:electron": "tsc -p tsconfig.electron.json --watch",
        "dev:app": "wait-on http-get://127.0.0.1:5173 dist-electron/electron/main.js && NODE_OPTIONS=--disable-warning=ExperimentalWarning ELECTRON_RENDERER_URL=http://127.0.0.1:5173 electronmon ."
    },
    "dependencies": {
        "@guolao/vue-monaco-editor": "^1.6.0",
        "tailwind-merge": "^3.5.0"
    },
    "devDependencies": {
        "@iconify/json": "^2.2.460",
        "@iconify/tailwind4": "^1.2.3",
        "@tailwindcss/vite": "^4.2.2",
        "@types/node": "^25.5.2",
        "@types/three": "^0.183.1",
        "@vitejs/plugin-vue": "^6.0.5",
        "@vue/test-utils": "^2.4.6",
        "concurrently": "^9.2.1",
        "electron": "^41.2.0",
        "electron-builder": "^26.8.1",
        "electronmon": "^2.0.4",
        "jsdom": "^29.0.2",
        "tailwindcss": "^4.2.2",
        "tsx": "^4.21.0",
        "typescript": "^6.0.2",
        "vite": "npm:@voidzero-dev/vite-plus-core@latest",
        "vite-plus": "^0.1.16",
        "vitest": "^4.1.3",
        "vue": "^3.5.32",
        "vue-tsc": "^3.2.6",
        "wait-on": "^9.0.4"
    },
    "overrides": {
        "vite": "npm:@voidzero-dev/vite-plus-core@latest"
    },
    "packageManager": "npm@11.12.1",
    "electronmon": {
        "patterns": [
            "!src/mainview/**",
            "!src/mainview/**/*",
            "!sandbox/**",
            "!sandbox/**/*",
            "scripts/build.ts",
            "scripts/prepare.ts",
            "scripts/release-audit.sh"
        ]
    },
    "productName": "Gitvan"
}
