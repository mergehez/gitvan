{
    "name": "gitvan",
    "version": "0.1.0",
    "description": "Gitvan desktop Git client with Vue and Vite",
    "license": "MIT",
    "author": {
        "name": "Mergesoft"
    },
    "type": "module",
    "scripts": {
        "build": "bun install && vp build && electrobun build",
        "test:ui": "vitest run",
        "release:audit": "bash ./scripts/release-audit.sh",
        "release:validate": "vitest run --exclude tests/App.real.spec.ts && bun run build",
        "release:mac": "bun run ./scripts/build.ts",
        "release:mac:signed": "bun run ./scripts/build.ts --signed",
        "release:mac:notarize": "bun run ./scripts/build.ts --notarize",
        "dev2": "pkill -f electrobun 2>/dev/null && pkill -f \"bun run\" 2>/dev/null && rm -rf dist/ || true && concurrently \"vp dev --port 5173\" \"vp build && electrobun dev --watch\" --names \"Vite,Electron\" --prefix-colors \"blue,green\"",
        "dev": "bun run src/backend/devServer.ts & sleep 2 && VITE_DEV2=true vp dev --port 5173",
        "build:canary": "electrobun build --env=canary",
        "build:stable": "electrobun build --env=stable",
        "lint": "oxfmt && oxlint --fix && vue-tsc --noEmit"
    },
    "dependencies": {
        "@guolao/vue-monaco-editor": "^1.6.0",
        "@xterm/addon-fit": "^0.11.0",
        "tailwind-merge": "^3.6.0",
        "xterm": "^5.3.0",
        "electrobun": "^1.18.1"
    },
    "devDependencies": {
        "@iconify/json": "^2.2.471",
        "@iconify/tailwind4": "^1.2.3",
        "@tailwindcss/vite": "^4.3.0",
        "@types/bun": "^1.3.13",
        "@types/node": "^25.6.2",
        "@types/three": "^0.184.1",
        "@vitejs/plugin-vue": "^6.0.6",
        "@vue/test-utils": "^2.4.10",
        "concurrently": "^9.2.1",
        "jsdom": "^29.1.1",
        "oxfmt": "^0.48.0",
        "oxlint": "^1.63.0",
        "tailwindcss": "^4.3.0",
        "tsx": "^4.21.0",
        "typescript": "^6.0.3",
        "vite": "^8.0.12",
        "vitest": "^4.1.6",
        "vue": "^3.5.34",
        "vue-tsc": "^3.2.8",
        "wait-on": "^9.0.10"
    },
    "packageManager": "bun@1.3.12",
    "productName": "Gitvan"
}
