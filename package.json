{
    "name": "gitvan",
    "version": "0.1.0",
    "description": "Gitvan desktop Git client with Vue and Vite",
    "license": "MIT",
    "author": {
        "name": "Mergesoft"
    },
    "type": "module",
    "scripts": {
        "build": "bun install && vp build && electrobun build",
        "test:ui": "vitest run",
        "release:audit": "bash ./scripts/release-audit.sh",
        "release:validate": "vitest run --exclude tests/App.real.spec.ts && bun run build",
        "release:mac": "bun run ./scripts/build.ts",
        "release:mac:signed": "bun run ./scripts/build.ts --signed",
        "release:mac:notarize": "bun run ./scripts/build.ts --notarize",
        "dev": "concurrently \"vp dev --port 5173\" \"vp build && electrobun dev --watch\"",
        "build:canary": "electrobun build --env=canary",
        "build:stable": "electrobun build --env=stable"
    },
    "dependencies": {
        "@guolao/vue-monaco-editor": "^1.6.0",
        "@xterm/addon-fit": "^0.11.0",
        "tailwind-merge": "^3.5.0",
        "xterm": "^5.3.0",
        "electrobun": "^1.16.0"
    },
    "devDependencies": {
        "@iconify/json": "^2.2.462",
        "@iconify/tailwind4": "^1.2.3",
        "@tailwindcss/vite": "^4.2.2",
        "@types/bun": "^1.3.12",
        "@types/node": "^25.6.0",
        "@types/three": "^0.183.1",
        "@vitejs/plugin-vue": "^6.0.6",
        "@vue/test-utils": "^2.4.6",
        "concurrently": "^9.2.1",
        "jsdom": "^29.0.2",
        "tailwindcss": "^4.2.2",
        "tsx": "^4.21.0",
        "typescript": "^6.0.2",
        "vite": "npm:@voidzero-dev/vite-plus-core",
        "vite-plus": "^0.1.16",
        "vitest": "^4.1.4",
        "vue": "^3.5.32",
        "vue-tsc": "^3.2.6",
        "wait-on": "^9.0.5"
    },
    "overrides": {
        "vite": "npm:@voidzero-dev/vite-plus-core@latest"
    },
    "packageManager": "bun@1.3.12",
    "productName": "Gitvan"
}
